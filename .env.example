# OpenDeepSeek 环境配置模板
# 复制为 .env 并填入你的 API Key

# DeepSeek API（必需）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here
HERMES_MODEL=deepseek-chat

# Hermes API Server（自动生成，无需修改）
HERMES_API_KEY=auto-generated-hermes-key

# Open WebUI（自动生成，无需修改）
WEBUI_SECRET_KEY=auto-generated-webui-key

# 可选：Tailscale 主机名（用于手机远程访问）
# TAILSCALE_HOSTNAME=opendeepseek
