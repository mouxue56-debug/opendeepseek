# OpenDeepSeek 环境变量模板
# 用法：cp .env.example .env，然后编辑 .env 填入你的配置
# 或运行 ./setup.sh 自动生成

# ============================================================
# 必填：DeepSeek API
# ============================================================
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 模型选择
# - deepseek-v4-flash：推荐，便宜快速（$0.14/1M 输入，$0.28/1M 输出）
# - deepseek-v4-pro：推理任务，1.6T MoE
# 兼容说明：deepseek-chat / deepseek-reasoner 将于 2026-07-24 弃用；
# 出于兼容，二者目前分别对应 deepseek-v4-flash 的非思考 / 思考模式。
# 新项目默认使用官方新模型名；只有旧 Hermes provider 不识别新名时，才临时用兼容别名兜底。
DEFAULT_MODEL=deepseek-v4-flash

# ============================================================
# 速度优先（推荐默认）
# ============================================================
# Open WebUI 的标题/标签/追问建议会额外调用模型。
# 在 OpenDeepSeek 里这些调用也会走 Hermes Agent，单次会附带工具上下文，
# 所以默认关闭，把 token 和等待时间留给主回复。
ENABLE_TITLE_GENERATION=false
ENABLE_TAGS_GENERATION=false
ENABLE_FOLLOW_UP_GENERATION=false

# 普通问答走 DeepSeek 轻量直连；真任务、图片、文件、提醒、记忆、工具调用走 Hermes Agent。
ENABLE_LIGHTWEIGHT_ROUTING=true
HERMES_AGENT_MAX_TOKENS=12000
HERMES_AGENT_STREAM=false
HERMES_PROGRESS_STREAM=true
HERMES_MAX_ITERATIONS=24
HERMES_API_TIMEOUT=300
HERMES_API_CALL_STALE_TIMEOUT=120
IMAGE_BRIDGE_TIMEOUT=600
OPDS_REALTIME_SEARCH_ENABLED=true
OPDS_REALTIME_SEARCH_URL=http://searxng:8080/search?q={query}&format=json
OPDS_REALTIME_SEARCH_TIMEOUT=4
OPDS_REALTIME_SEARCH_MAX_RESULTS=6
ENABLE_RAG_WEB_SEARCH=false

# 小白本机默认资源上限，避免 Docker/OrbStack 抢完整台电脑。
HERMES_CPUS=1.5
HERMES_MEMORY_LIMIT=1536m
WEBUI_CPUS=1.0
WEBUI_MEMORY_LIMIT=1280m
BRIDGE_CPUS=0.5
BRIDGE_MEMORY_LIMIT=256m
SEARXNG_CPUS=0.5
SEARXNG_MEMORY_LIMIT=512m

# Hermes Memory 与轻量问答共享的偏好快照（容器内路径）。
# 用户明确说"记住..."时，Hermes 会维护这份摘要；普通问答直连 DeepSeek 前会读取它。
OPDS_SHARED_MEMORY_PATH=/host/OpenDeepSeek-Memory/profile.md
OPDS_MEMORY_SNAPSHOT_MAX_CHARS=4000
# /host 路径在用户电脑上的显示前缀。setup.sh 会用 HERMES_HOST_DIR 自动填好。
OPDS_HOST_DISPLAY_PREFIX=/Users/yourname

# ============================================================
# 自动生成（setup.sh 会随机生成；手动安装时用 openssl rand -hex 32）
# ============================================================
HERMES_API_KEY=auto-generated-by-setup
WEBUI_SECRET_KEY=auto-generated-by-setup

# ============================================================
# 真 Agent 文件系统权限
# ============================================================
# Hermes 容器内会把这个目录挂载为 /host，并把 terminal/file 工具工作目录设为 /host。
# 默认安装会写成你的用户家目录，这样可以在 WebUI 里访问 /host/Desktop、/host/Documents 等。
# 如果你想收窄权限，改成一个专用文件夹，例如：
# HERMES_HOST_DIR=./agent-files
HERMES_HOST_DIR=/Users/yourname

# ============================================================
# IM 桥接：钉钉
# 申请位置：钉钉开发者后台 → 应用开发 → 机器人
# 启用方式：取消下方注释填入凭证 → docker compose restart hermes
# ============================================================
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=
# DINGTALK_ALLOWED_USERS=

# ============================================================
# IM 桥接：飞书
# 申请位置：飞书开放平台 → 创建企业自建应用
# ============================================================
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_DOMAIN=feishu

# ============================================================
# IM 桥接：企业微信（WeCom）
# 申请位置：企业微信管理后台 → 应用管理 → 自建应用
# ============================================================
# WECOM_BOT_ID=
# WECOM_SECRET=
# WECOM_ALLOWED_USERS=

# ============================================================
# IM 桥接：邮件（IMAP + SMTP）
# 服务器地址参考 docs/IM-BRIDGE.md
# 注意：QQ 邮箱要用"授权码"，不是登录密码
# ============================================================
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=imap.exmail.qq.com
# EMAIL_SMTP_HOST=smtp.exmail.qq.com

# ============================================================
# IM 桥接：QQ Bot（QQ 官方机器人）
# 申请位置：q.qq.com 开放平台
# ============================================================
# QQ_APP_ID=
# QQ_CLIENT_SECRET=

# ============================================================
# IM 桥接：Matrix（开源去中心 IM）
# ============================================================
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=
# MATRIX_USER_ID=

# ============================================================
# IM 桥接：Webhook（自定义集成）
# ============================================================
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=8644

# ============================================================
# 其他可选
# ============================================================
# Tailscale 主机名（用于手机/异地远程访问）
# TAILSCALE_HOSTNAME=opendeepseek
