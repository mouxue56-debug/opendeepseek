# OpenDeepSeek CN 环境变量模板
# 用法：cp .env.example.cn .env，然后填写 DEEPSEEK_API_KEY
# 注意：不要把 .env 提交到 Git。

OPDS_REGION=cn

# ============================================================
# LLM Provider：默认 DeepSeek，高级用户可切自定义 OpenAI-compatible API
# ============================================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEFAULT_MODEL=deepseek-v4-flash

OPDS_LLM_PROVIDER=deepseek
OPDS_LLM_BASE_URL=https://api.deepseek.com
OPDS_LLM_API_KEY=your-deepseek-api-key-here
OPDS_LLM_MODEL=deepseek-v4-flash
OPDS_LLM_PRO_MODEL=deepseek-v4-pro

# 自定义 OpenAI-compatible API（OpenRouter、本地 Ollama/LM Studio/vLLM、阿里百炼、火山方舟、硅基流动、LiteLLM、自建网关等）
OPDS_CUSTOM_LLM_BASE_URL=
OPDS_CUSTOM_LLM_API_KEY=
OPDS_CUSTOM_LLM_MODEL=
OPDS_CUSTOM_LLM_PRO_MODEL=

# Hermes 底层 provider。DeepSeek 默认 deepseek；自定义 API 用 custom。
HERMES_INFERENCE_PROVIDER=deepseek
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_NAME=

# ============================================================
# OpenDeepSeek 产品化模型
# ============================================================
DEFAULT_MODELS_FRONTEND=opendeepseek-auto
DEFAULT_PINNED_MODELS=opendeepseek-auto,opendeepseek-fast,opendeepseek-agent,opendeepseek-deepwork

# ============================================================
# 镜像与依赖源
# ============================================================
# 默认使用当前已公开可拉的上游镜像，保证今天就能跑。
# 等 OpenDeepSeek CN 镜像发布后，可把下面四项改成国内 ACR/CCR 镜像。
HERMES_IMAGE=nousresearch/hermes-agent:v2026.4.23
BRIDGE_IMAGE=opendeepseek-hermes-bridge:cn-local
OPENWEBUI_IMAGE=openwebui/open-webui:0.9.2
SEARXNG_IMAGE=searxng/searxng:2026.4.28-ed5955a5c

# 预留：未来国内镜像仓库发布后使用。
OPDS_IMAGE_REGISTRY=registry.cn-hangzhou.aliyuncs.com/opendeepseek
OPDS_VERSION=0.5.0-cn

PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
PNPM_REGISTRY=https://registry.npmmirror.com

# ============================================================
# Open WebUI 中文默认
# ============================================================
WEBUI_NAME=OpenDeepSeek
DEFAULT_LOCALE=zh-CN
WEBUI_AUTH=false
ENABLE_COMMUNITY_SHARING=false
ENABLE_VERSION_UPDATE_CHECK=false
ENABLE_EASTER_EGGS=false
ENABLE_TITLE_GENERATION=false
ENABLE_TAGS_GENERATION=false
ENABLE_FOLLOW_UP_GENERATION=false
ENABLE_CODE_INTERPRETER=false

# 默认只绑定本机；公网/局域网部署必须先读 docs/SECURITY.md。
BIND_HOST=127.0.0.1

# ============================================================
# Smart Bridge 路由与 Agent 预算
# ============================================================
ENABLE_LIGHTWEIGHT_ROUTING=true
HERMES_AGENT_MAX_TOKENS=32768
HERMES_AGENT_STREAM=false
HERMES_PROGRESS_STREAM=true
HERMES_MAX_ITERATIONS=24
HERMES_API_TIMEOUT=300
HERMES_API_CALL_STALE_TIMEOUT=120
IMAGE_BRIDGE_TIMEOUT=600
OPDS_DELEGATE_OPENWEBUI_NATIVE_TOOLS=true

# ============================================================
# 国内搜索
# ============================================================
OPDS_SEARCH_PROVIDER=auto
# CN 轻量默认不开实时搜索，避免默认启动 SearXNG 增加内存占用。
# 需要联网搜索时改成 true；install-cn.sh 会自动启用 compose full profile。
OPDS_REALTIME_SEARCH_ENABLED=false
OPDS_REALTIME_SEARCH_URL=http://searxng:8080/search?q={query}&format=json
OPDS_REALTIME_SEARCH_TIMEOUT=4
OPDS_REALTIME_SEARCH_MAX_RESULTS=6
ENABLE_RAG_WEB_SEARCH=false
SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>&format=json

# 可选：Bocha/Jina/Bing 等国内可用搜索增强，不填则跳过。
BOCHA_SEARCH_API_KEY=
JINA_API_KEY=
BING_SEARCH_V7_SUBSCRIPTION_KEY=

# ============================================================
# RAG / 中文模型
# ============================================================
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
ENABLE_RAG_HYBRID_SEARCH=false

# 在线国内版不要默认 OFFLINE_MODE=true；离线包会预置缓存后再启用。
OFFLINE_MODE=false
HF_HUB_OFFLINE=false

# ============================================================
# Agent 文件权限
# ============================================================
# CN 默认建议收窄到专用目录。需要桌面/下载/文档权限时由 onboarding/Portal 明确授权。
HERMES_HOST_DIR=${HOME}/OpenDeepSeek-Agent
OPDS_SHARED_MEMORY_PATH=/host/OpenDeepSeek-Memory/profile.md
OPDS_MEMORY_SNAPSHOT_MAX_CHARS=4000
OPDS_HOST_DISPLAY_PREFIX=${HOME}/OpenDeepSeek-Agent

# 本地产物中心：Bridge 会为 OpenDeepSeek-Outputs 下的生成文件写 manifest，
# 并通过本机 127.0.0.1:${OPDS_ARTIFACT_PORT} 提供只读预览。
OPDS_ARTIFACT_PORT=8770
OPDS_ARTIFACT_ROOT=/host/OpenDeepSeek-Outputs
OPDS_ARTIFACT_PUBLIC_BASE_URL=http://localhost:8770
OPDS_ARTIFACT_MAX_FILES=100

# ============================================================
# 自动生成。install-cn.sh / onboarding 会随机写入真实值。
# ============================================================
HERMES_API_KEY=auto-generated-by-install-cn
WEBUI_SECRET_KEY=auto-generated-by-install-cn

# ============================================================
# 本机资源上限
# ============================================================
HERMES_CPUS=1.5
HERMES_MEMORY_LIMIT=1280m
WEBUI_CPUS=1.0
WEBUI_MEMORY_LIMIT=1024m
BRIDGE_CPUS=0.5
BRIDGE_MEMORY_LIMIT=256m
SEARXNG_CPUS=0.5
SEARXNG_MEMORY_LIMIT=384m
